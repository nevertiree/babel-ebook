{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BabelEbook",
  "version": "0.4.2",
  "identifier": "com.nevertiree.babel-ebook",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "license": "MIT",
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      },
      "deb": {
        "depends": []
      }
    },
    "windows": {
      "nsis": {
        "languages": [
          "English",
          "Spanish",
          "Japanese",
          "Korean",
          "Russian",
          "SimpChinese"
        ],
        "displayLanguageSelector": false
      },
      "wix": {
        "language": {
          "en-US": {
            "localePath": "wix-locale/en-US.wxl"
          }
        }
      }
    }
  }
}
